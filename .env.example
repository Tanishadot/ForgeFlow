# ── NVIDIA NIM ────────────────────────────────────────────────────────────────
# Get your key at https://integrate.api.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here

# NIM inference endpoint (default is the hosted NVIDIA API)
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model to use for chat and explanations
NVIDIA_NIM_MODEL=meta/llama-3.1-8b-instruct

# Request timeout in seconds
NVIDIA_NIM_TIMEOUT_SECONDS=30

# Token limits
NVIDIA_NIM_MAX_TOKENS_CHAT=800
NVIDIA_NIM_MAX_TOKENS_EXPLAIN=1200

# Sampling temperature (lower = more deterministic)
NVIDIA_NIM_TEMPERATURE=0.2
